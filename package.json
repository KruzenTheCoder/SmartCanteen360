{
  "name": "smartcanteen360",
  "version": "0.1.0",
  "private": true,
  "description": "SmartCanteen 360 — enterprise digital canteen management platform (web admin, mobile, API).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @smartcanteen/database generate",
    "db:migrate": "pnpm --filter @smartcanteen/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @smartcanteen/database migrate:deploy",
    "db:push": "pnpm --filter @smartcanteen/database push",
    "db:seed": "pnpm --filter @smartcanteen/database seed",
    "db:studio": "pnpm --filter @smartcanteen/database studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
