{
  "name": "smartcanteen360",
  "version": "0.1.0",
  "private": true,
  "description": "SmartCanteen 360 — enterprise digital canteen management platform (web admin, mobile, API).",
  "//": "npm `workspaces` lists ONLY apps/web so Vercel's default `npm install` at the repo root installs & hoists next there (where Vercel detects the framework). Local dev still uses pnpm via pnpm-workspace.yaml, which npm ignores.",
  "workspaces": ["apps/web"],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @smartcanteen/database generate",
    "db:migrate": "pnpm --filter @smartcanteen/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @smartcanteen/database migrate:deploy",
    "db:push": "pnpm --filter @smartcanteen/database push",
    "db:seed": "pnpm --filter @smartcanteen/database seed",
    "db:studio": "pnpm --filter @smartcanteen/database studio"
  },
  "dependencies": {
    "next": "^14.2.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
