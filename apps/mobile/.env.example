# ============================================================================
# NetBite360 mobile (Expo). Copy to `.env`. EXPO_PUBLIC_* vars are embedded in
# the app bundle — only ever put the PUBLIC anon key here, never the service key.
# ============================================================================

# Supabase Auth (login). Use the rotated ANON/publishable key.
EXPO_PUBLIC_SUPABASE_URL="https://pdhxupijqghvazslhkme.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="<your-rotated-anon-or-publishable-key>"

# Data API = the deployed NetBite360 web app's /api routes.
EXPO_PUBLIC_API_URL="https://<your-web-app>.vercel.app/api"
