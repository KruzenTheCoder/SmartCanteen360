# ============================================================================
# NetBite360 — web env. Copy to `.env.local` for local dev, and set these in
# Vercel → Settings → Environment Variables for production.
#
# ⚠️  Use ROTATED keys. Anything pasted into chat/support must be regenerated in
#     Supabase (Settings → Database: reset password; Settings → API: rotate keys).
# ============================================================================

# ---- Mode -------------------------------------------------------------------
# "false" = production (real Supabase auth + data). Omit / "true" = demo mode.
NEXT_PUBLIC_DEMO_MODE="false"

# ---- Supabase (public — safe to expose to the browser; protected by RLS) ----
NEXT_PUBLIC_SUPABASE_URL="https://pdhxupijqghvazslhkme.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-rotated-anon-or-publishable-key>"

# ---- Supabase (SERVER ONLY — never prefix with NEXT_PUBLIC, never commit) ---
# Used by the service-role admin client for provisioning/super-admin actions.
SUPABASE_SERVICE_ROLE_KEY="<your-rotated-service-role-key>"
